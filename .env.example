# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fund_cpkku
DB_USERNAME=
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=
JWT_EXPIRE_HOURS=1

# Refresh Token Configuration
# Refresh token expiry in hours (30 วัน = 720 ชั่วโมง)
REFRESH_TOKEN_EXPIRE_HOURS=720

# Server Configuration
SERVER_PORT=8080
# GIN_MODE=debug (for dev)
GIN_MODE=release

# CORS Configuration
ALLOWED_ORIGINS=
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# TLS Configuration (optional, enable HTTPS when both are set)
# Use forward slashes on Windows to avoid escaping issues.
TLS_CERT_FILE=
TLS_KEY_FILE=
SERVER_HTTPS_PORT=8443

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=10485760
TEMP_FILE_CLEANUP_DAYS=7

# Security Configuration
BCRYPT_COST=12
# Session timeout in seconds (12 hours)
SESSION_TIMEOUT=43200
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Session Management Configuration
# ทำความสะอาด expired sessions ทุก 1 ชั่วโมง (วินาที)
SESSION_CLEANUP_INTERVAL=3600
# จำนวน session สูงสุดต่อ user
MAX_SESSIONS_PER_USER=5
# Timeout เมื่อไม่มีการใช้งาน (2 ชั่วโมง)
SESSION_INACTIVITY_TIMEOUT=7200

# Token Security Configuration
# เปิดใช้ token blacklist
ENABLE_TOKEN_BLACKLIST=true
# หมุน refresh token ทุกครั้งที่ใช้ (ปิดไว้ก่อน)
TOKEN_ROTATION_ENABLED=false

# API Configuration
API_RATE_LIMIT=100
API_RATE_WINDOW=3600

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Email Configuration (สำหรับแจ้งเตือนการ login)
APP_BASE_URL=
APP_BACKEND_BASE_URL=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=
SMTP_USER=
SMTP_PASS=
# เฉพาะ Dev/ทดสอบเท่านั้น (โปรดปิดใน Production)
SMTP_SKIP_TLS_VERIFY=0
SMTP_IMPLICIT_TLS=0

# Security Alerts Configuration
# แจ้งเตือนการ login จาก device ใหม่
ENABLE_LOGIN_ALERTS=true
ENABLE_SUSPICIOUS_ACTIVITY_DETECTION=true
# จำนวน session พร้อมกันสูงสุด
MAX_CONCURRENT_SESSIONS=3

# Development/Production Flags
# development | staging | production
ENVIRONMENT=production
# แสดง SQL queries (ปิดใน production)
DEBUG_SQL=false
# log ทุก request
ENABLE_REQUEST_LOGGING=true

# Cache Configuration (สำหรับอนาคต)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Cache timeout (วินาที)
CACHE_TTL=3600

# Backup Configuration
# สำรองข้อมูลอัตโนมัติ
AUTO_BACKUP_ENABLED=false
# ทุกวันเวลา 02:00 (cron format)
BACKUP_SCHEDULE=0 2 * * *
# เก็บ backup 30 วัน
BACKUP_RETENTION_DAYS=30

# Scholar Import Configuration
VENV_PY=python
SCHOLAR_SCRIPT=./scripts/scholarly_fetch.py

# Document Generation Configuration
# Path to LibreOffice soffice executable (set this on Windows servers)
# Example: C:/Program Files/LibreOffice/program/soffice.exe
LIBREOFFICE_PATH=
CP_PROFILE_SCRIPT=./scripts/scrape_kku_people.py

# KKU SSONext Configuration
SSO_ENV=prod
SSO_APP_ID=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URL=
SSO_LOGOUT_REDIRECT_URL=
SSO_REQUEST_TIMEOUT_SECONDS=15

# Auth cookie name (JWT cookie)
AUTH_COOKIE_NAME=auth_token
